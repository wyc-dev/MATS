# ─── AMACRF Configuration ───
# Adaptive Multi-Agent Chaotic Regime Framework
# Copy this file to .env and fill in your values.

# ═══════════════════════════════════════════════════════════════
# BINANCE — Required for WebSocket market data
# ═══════════════════════════════════════════════════════════════
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=                          # Optional — for real trading
BINANCE_WS_URL=wss://stream.binance.com:9443/ws
BINANCE_FUTURES_WS_URL=wss://fstream.binance.com/ws
BINANCE_REST_URL=https://api.binance.com
BINANCE_FUTURES_REST_URL=https://fapi.binance.com
BINANCE_USE_FUTURES=true

# ═══════════════════════════════════════════════════════════════
# HYPERLIQUID — Optional, for real trading on Hyperliquid
# ═══════════════════════════════════════════════════════════════
HYPERLIQUID_WALLET_ADDRESS=                  # Your Arbitrum wallet address
HYPERLIQUID_PRIVATE_KEY=                     # Your private key (secp256k1)

# ═══════════════════════════════════════════════════════════════
# NVIDIA NIM — Optional (leave blank to use Ollama)
# ═══════════════════════════════════════════════════════════════
NIM_API_KEY=
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_MODEL_DEFAULT=meta/llama-3.3-70b-instruct
NIM_MODEL_FAST=nvidia/llama-3.1-nemotron-8b-instruct
NIM_MODEL_STRONG=deepseek-ai/deepseek-r1

# ═══════════════════════════════════════════════════════════════
# OLLAMA — Primary LLM provider when NIM unavailable
# ═══════════════════════════════════════════════════════════════
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_DEFAULT=kimi-k2.6:cloud          # Sub-agents default

# ═══════════════════════════════════════════════════════════════
# PAPER TRADING — Simulation parameters
# ═══════════════════════════════════════════════════════════════
PAPER_INITIAL_BALANCE=1000
PAPER_MAX_POSITION_SIZE_PCT=0.20
PAPER_MAX_DRAWDOWN_PCT=0.20
PAPER_DAILY_LOSS_LIMIT_PCT=0.05

# ═══════════════════════════════════════════════════════════════
# RISK — Position sizing, SL/TP, veto thresholds
# ═══════════════════════════════════════════════════════════════
RISK_MAX_LEVERAGE=1.0
RISK_STOP_LOSS_PCT=0.02
RISK_TAKE_PROFIT_PCT=0.05
RISK_TRAILING_STOP_PCT=0.015
RISK_VETO_THRESHOLD=0.85

# ═══════════════════════════════════════════════════════════════
# HACP — Hyper-Accelerated Cognition Protocol (debate engine)
# ═══════════════════════════════════════════════════════════════
HACP_PARALLEL_THINKING_TIMEOUT_MS=15000
HACP_MAX_DEBATE_ROUNDS=3
HACP_CONSENSUS_THRESHOLD=0.60
HACP_TOTAL_TIMEOUT_MS=120000
HACP_STAGGER_DELAY_MS=4000

# ═══════════════════════════════════════════════════════════════
# SIGMOID·GA — Genetic algorithm for sentiment analysis
# ═══════════════════════════════════════════════════════════════
GA_POPULATION_SIZE=20
GA_MUTATION_RATE=0.15
GA_CROSSOVER_RATE=0.70

# ═══════════════════════════════════════════════════════════════
# SYSTEM — Logging, timing, ports
# ═══════════════════════════════════════════════════════════════
LOG_LEVEL=info           # error | warn | info | debug
NODE_ENV=development      # development | production | test
HEARTBEAT_INTERVAL_MS=30000
DECISION_INTERVAL_MS=60000   # 60s between decision cycles
NIM_CALL_TIMEOUT_MS=120000
API_PORT=3456