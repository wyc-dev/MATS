# ─── MATS Configuration ───
# Multi-Agent Trading System
# Copy this file to .env and fill in your values.

# ═══════════════════════════════════════════════════════════════
# OLLAMA — Primary LLM provider
# ═══════════════════════════════════════════════════════════════
# Local Ollama (free, no API key) or Ollama Pro (cloud models)
# Recommended: Upgrade to Ollama Pro for cloud model access
# (deepseek-v4-flash:cloud, kimi-k2.6:cloud, glm-5.2:cloud)
# — faster inference, no local GPU, supports 8-agent concurrency
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_DEFAULT=kimi-k2.6:cloud

# ═══════════════════════════════════════════════════════════════
# HYPERLIQUID — Wallet for real trading + WS user-level feeds
# ═══════════════════════════════════════════════════════════════
# Leave blank for paper trading mode.
# When filled, the system can:
#   - Place real orders on Hyperliquid
#   - Subscribe to clearinghouseState + userFills WS feeds
#   - Display real wallet balance/equity in the UI
HYPERLIQUID_WALLET_ADDRESS=                  # Your Arbitrum wallet address (0x...)
HYPERLIQUID_PRIVATE_KEY=                     # Your private key (secp256k1, 64 hex chars)

# ═══════════════════════════════════════════════════════════════
# PAPER TRADING — Simulation parameters
# ═══════════════════════════════════════════════════════════════
PAPER_INITIAL_BALANCE=1000
PAPER_MAX_POSITION_SIZE_PCT=0.20
PAPER_MAX_DRAWDOWN_PCT=0.20
PAPER_DAILY_LOSS_LIMIT_PCT=0.05

# ═══════════════════════════════════════════════════════════════
# RISK — Position sizing, SL/TP, veto thresholds
# ═══════════════════════════════════════════════════════════════
RISK_MAX_LEVERAGE=1.0
RISK_STOP_LOSS_PCT=0.02
RISK_TAKE_PROFIT_PCT=0.05
RISK_TRAILING_STOP_PCT=0.015
RISK_VETO_THRESHOLD=0.85

# ═══════════════════════════════════════════════════════════════
# HACP — Hyper-Accelerated Cognition Protocol (debate engine)
# ═══════════════════════════════════════════════════════════════
HACP_PARALLEL_THINKING_TIMEOUT_MS=15000
HACP_MAX_DEBATE_ROUNDS=3
HACP_CONSENSUS_THRESHOLD=0.60
HACP_TOTAL_TIMEOUT_MS=120000
HACP_STAGGER_DELAY_MS=4000

# ═══════════════════════════════════════════════════════════════
# SIGMOID·GA — Genetic algorithm for sentiment analysis
# ═══════════════════════════════════════════════════════════════
GA_POPULATION_SIZE=20
GA_MUTATION_RATE=0.15
GA_CROSSOVER_RATE=0.70

# ═══════════════════════════════════════════════════════════════
# MASSIVE.COM — Options Data Layer (v2.0.58)
# Required for Stocks/RWA trading — provides IV Rank, Greeks, P/C ratio
# Get your API key at https://massive.com
# ═══════════════════════════════════════════════════════════════
MASSIVE_API_KEY=

# ═══════════════════════════════════════════════════════════════
# EXP — Thesis Experience Vector Memory (v2.0.138)
# ═══════════════════════════════════════════════════════════════
EXP_ENABLED=false
EXP_EMBED_MODEL=Xenova/all-MiniLM-L6-v2
EXP_EMBED_DIM=384
EXP_MAX_RECORDS=200
EXP_MATCH_THRESHOLD=0.55
EXP_WIN_PROB_THRESHOLD=0.6
EXP_LOSS_PROB_THRESHOLD=0.4
EXP_DELTA_THRESHOLD=0.55
EXP_MIN_DELTA_SAMPLES=2
EXP_DELTA_WIN_RATE_THRESHOLD=0.6
EXP_DELTA_LOSS_RATE_THRESHOLD=0.4
EXP_ALLOW_REVERSE=true
EXP_BREAKEVEN_IS=exclude
EXP_SIMILARITY_MODE=asymmetric

# ═══════════════════════════════════════════════════════════════
# EXP DIGEST — A2A Experience Digestion (v2.0.140)
# 三層經驗消化: LLM lesson digestion → embedding → classification
# ═══════════════════════════════════════════════════════════════
EXP_DIGEST_ENABLED=true
EXP_DIGEST_CLASSIFY_THRESHOLD=0.72
EXP_DIGEST_CLUSTER_THRESHOLD=0.80
EXP_DIGEST_MIN_CLASS_SIZE=2
EXP_DIGEST_CLASS_WIN_THRESHOLD=0.6
EXP_DIGEST_CLASS_LOSS_THRESHOLD=0.4
EXP_DIGEST_MAX_CACHE=300

# ═══════════════════════════════════════════════════════════════
# SYSTEM — Logging, timing, ports
# ═══════════════════════════════════════════════════════════════
LOG_LEVEL=info           # error | warn | info | debug
NODE_ENV=development      # development | production | test
HEARTBEAT_INTERVAL_MS=30000
DECISION_INTERVAL_MS=300000   # 5 min between decision cycles
API_PORT=3456